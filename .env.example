OPENAI_API_KEY=
PORT=4000
# RDS PostgreSQL (same for dev and production - prototype)
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require
DATABASE_URL="postgresql://pmm_admin:YOUR_PASSWORD@your-rds-endpoint:5432/pmm?schema=public&sslmode=require"
WIDGET_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"
JSON_BODY_LIMIT=100kb
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_TOKEN_MAX=30
PUBLIC_RATE_LIMIT_LEAD_MAX=20
PUBLIC_RATE_LIMIT_SCORE_MAX=20
OPENAI_TIMEOUT_MS=12000
OPENAI_MAX_RETRIES=1
LOG_LEVEL=info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_BASE_URL=
TWILIO_WEBHOOK_AUTH_SECRET=
PHONE_RATE_LIMIT_CALLS_MAX=10
PHONE_ALLOWED_ORIGINS=
PUBLIC_RATE_LIMIT_SMS_SEND_MAX=30
PUBLIC_RATE_LIMIT_SMS_START_MAX=20
SMS_QUIET_HOURS_START=
SMS_QUIET_HOURS_END=
