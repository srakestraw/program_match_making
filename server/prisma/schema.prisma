generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TraitCategory {
  ACADEMIC
  INTERPERSONAL
  MOTIVATION
  EXPERIENCE
  LEADERSHIP
  PROBLEM_SOLVING
}

enum TraitQuestionType {
  CHAT
  QUIZ
}

enum ProgramTraitPriorityBucket {
  CRITICAL
  VERY_IMPORTANT
  IMPORTANT
  NICE_TO_HAVE
}

enum PreferredChannel {
  email
  sms
  phone
}

enum LeadSource {
  widget
  import
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  APPLIED
  DISQUALIFIED
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
  CANCELED
}

enum CandidateSessionChannel {
  WEB_VOICE
  WEB_CHAT
  WEB_QUIZ
  PHONE_VOICE
  SMS
}

enum SmsDirection {
  INBOUND
  OUTBOUND
}

enum SmsDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  UNDELIVERED
  RECEIVED
}

enum SmsSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  OPTED_OUT
}

enum ConversationScenarioStage {
  AWARENESS
  CONSIDERATION
  OBJECTION
}

enum ConversationPersona {
  STUDENT
  PARENT
  INTERNATIONAL
}

enum ConversationTurnRole {
  USER
  ASSISTANT
  SYSTEM
}

model Candidate {
  id               String            @id @default(cuid())
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  preferredChannel PreferredChannel?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         CandidateSession[]
  leads            Lead[]

  @@index([email])
  @@index([phone])
}

model CandidateSession {
  id        String           @id @default(cuid())
  candidateId String?
  programId String?
  mode      String
  sessionLanguageTag String @default("en")
  channel   CandidateSessionChannel @default(WEB_VOICE)
  status    String
  startedAt DateTime         @default(now())
  endedAt   DateTime?
  candidate Candidate?       @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  program   Program?         @relation(fields: [programId], references: [id], onDelete: SetNull)
  turns     TranscriptTurn[]
  scorecards Scorecard[]
  traitScores CandidateTraitScore[]
  callSessions CallSession[]
  smsSessions SmsSession[]

  @@index([candidateId])
  @@index([programId])
}

model CandidateTraitScore {
  id            String           @id @default(cuid())
  sessionId     String
  traitId       String
  score0to5     Float
  confidence0to1 Float
  evidenceJson  String
  rationale     String?
  updatedAt     DateTime         @updatedAt
  createdAt     DateTime         @default(now())
  session       CandidateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  trait         Trait            @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([sessionId, traitId])
  @@index([sessionId])
  @@index([traitId])
}

model TranscriptTurn {
  id        String   @id @default(cuid())
  sessionId String
  ts        DateTime
  speaker   String
  text      String
  session   CandidateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Trait {
  id                    String         @id @default(cuid())
  name                  String         @unique
  category              TraitCategory
  definition            String?
  rubricScaleMin        Int            @default(0)
  rubricScaleMax        Int            @default(5)
  rubricPositiveSignals String?
  rubricNegativeSignals String?
  rubricFollowUps       String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  questions             TraitQuestion[]
  programTraits         ProgramTrait[]
  traitScores           TraitScore[]
  candidateTraitScores  CandidateTraitScore[]
}

model TraitQuestion {
  id           String            @id @default(cuid())
  traitId      String
  type         TraitQuestionType
  prompt       String
  optionsJson  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  trait        Trait             @relation(fields: [traitId], references: [id], onDelete: Cascade)
  traitScores  TraitScore[]

  @@index([traitId])
}

model Program {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  degreeLevel String?
  department  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  traits      ProgramTrait[]
  scorecards  Scorecard[]
  sessions    CandidateSession[]
  leads       Lead[]
}

model ProgramTrait {
  id        String                     @id @default(cuid())
  programId String
  traitId   String
  bucket    ProgramTraitPriorityBucket
  sortOrder Int
  notes     String?
  program   Program                    @relation(fields: [programId], references: [id], onDelete: Cascade)
  trait     Trait                      @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([programId, traitId])
  @@index([programId, bucket, sortOrder])
  @@index([traitId])
}

model BrandVoice {
  id            String     @id @default(cuid())
  name          String     @unique
  primaryTone   String     @default("professional")
  ttsVoiceName  String     @default("alloy")
  toneModifiers String[]   @default([])
  toneProfile   Json       @default("{\"formality\":75,\"warmth\":60,\"directness\":65,\"confidence\":70,\"energy\":55}")
  styleFlags    String[]   @default(["clear", "credible", "supportive", "future_focused"])
  avoidFlags    String[]   @default(["jargon_heavy", "overly_salesy", "impersonal"])
  canonicalExamples Json   @default("[]")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  simulations   ConversationSimulation[]
}

model ConversationScenario {
  id        String                    @id @default(cuid())
  title     String
  stage     ConversationScenarioStage
  persona   ConversationPersona?
  seedPrompt String
  isPreset  Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  simulations ConversationSimulation[]
}

model ConversationSimulation {
  id             String               @id @default(cuid())
  brandVoiceId   String
  scenarioId     String?
  persona        ConversationPersona
  customScenario String?
  stabilityScore Int?
  createdAt      DateTime             @default(now())
  brandVoice     BrandVoice           @relation(fields: [brandVoiceId], references: [id], onDelete: Cascade)
  scenario       ConversationScenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  turns          ConversationTurn[]
  voiceSamples   VoiceSample[]

  @@index([brandVoiceId])
}

model ConversationTurn {
  id           String               @id @default(cuid())
  simulationId String
  role         ConversationTurnRole
  content      String
  createdAt    DateTime             @default(now())
  order        Int
  simulation   ConversationSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  voiceSamples VoiceSample[]

  @@index([simulationId, order])
}

model VoiceSample {
  id           String                 @id @default(cuid())
  simulationId String
  turnId       String
  provider     String                 @default("stub")
  voiceName    String?
  audioUrl     String
  createdAt    DateTime               @default(now())
  simulation   ConversationSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  turn         ConversationTurn       @relation(fields: [turnId], references: [id], onDelete: Cascade)

  @@index([simulationId])
}

model Scorecard {
  id           String           @id @default(cuid())
  sessionId    String
  programId    String
  overallScore Float
  createdAt    DateTime         @default(now())
  session      CandidateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  program      Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  traitScores  TraitScore[]

  @@index([sessionId])
  @@index([programId])
}

model TraitScore {
  id           String                     @id @default(cuid())
  scorecardId  String
  traitId      String
  traitQuestionId String?
  bucket       ProgramTraitPriorityBucket
  score0to5    Float
  confidence   Float
  evidenceJson String
  rationale    String?
  scoredAt     DateTime                   @default(now())
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  scorecard    Scorecard                  @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  traitQuestion TraitQuestion?            @relation(fields: [traitQuestionId], references: [id], onDelete: SetNull)
  trait        Trait                      @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@index([scorecardId])
  @@index([traitId])
  @@index([traitQuestionId])
}

model Lead {
  id              String     @id @default(cuid())
  candidateId     String
  programId       String?
  source          LeadSource @default(widget)
  status          LeadStatus @default(NEW)
  owner           String?
  notes           String?
  lastContactedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  candidate       Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  program         Program?   @relation(fields: [programId], references: [id], onDelete: SetNull)
  callSessions    CallSession[]
  smsSessions     SmsSession[]

  @@index([candidateId])
  @@index([programId])
  @@index([status])
}

model CallSession {
  id                 String          @id @default(cuid())
  candidateSessionId String
  leadId             String?
  toPhone            String
  fromPhone          String
  provider           String          @default("twilio")
  status             CallStatus      @default(INITIATED)
  twilioCallSid      String?         @unique
  streamSid          String?
  startedAt          DateTime?
  endedAt            DateTime?
  failureReason      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  candidateSession   CandidateSession @relation(fields: [candidateSessionId], references: [id], onDelete: Cascade)
  lead               Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([candidateSessionId])
  @@index([leadId])
  @@index([status])
}

model SmsSession {
  id                 String           @id @default(cuid())
  candidateSessionId String
  leadId             String?
  phone              String
  status             SmsSessionStatus @default(ACTIVE)
  currentStep        Int              @default(0)
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  optedOutAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  candidateSession   CandidateSession @relation(fields: [candidateSessionId], references: [id], onDelete: Cascade)
  lead               Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages           SmsMessage[]

  @@index([candidateSessionId])
  @@index([leadId])
  @@index([phone])
  @@index([status])
}

model SmsMessage {
  id               String             @id @default(cuid())
  smsSessionId     String
  direction        SmsDirection
  body             String
  twilioMessageSid String?            @unique
  deliveryStatus   SmsDeliveryStatus?
  errorCode        String?
  errorMessage     String?
  createdAt        DateTime           @default(now())
  smsSession       SmsSession         @relation(fields: [smsSessionId], references: [id], onDelete: Cascade)

  @@index([smsSessionId])
}
